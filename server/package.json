{
    "name": "tailorflow-server",
    "version": "1.0.1",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc && node -e \"require('fs').copyFileSync('src/db/schema.sql', 'dist/db/schema.sql')\"",
        "start": "node dist/index.js",
        "init-db": "tsx src/db/init.ts"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^12.6.2",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "node-cron": "^4.2.1",
        "uuid": "^9.0.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/express-rate-limit": "^5.1.3",
        "@types/helmet": "^0.0.48",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.10.0",
        "@types/node-cron": "^3.0.11",
        "@types/uuid": "^9.0.7",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}
